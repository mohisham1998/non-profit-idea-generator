# Minimal Configuration for Getting Started
# ==========================================
# Copy this to .env and fill in the required values

# Database (Use these defaults for Docker)
DATABASE_URL=postgresql://nonprofit_user:nonprofit_password_change_me@postgres:5432/nonprofit_ideas

# Security - CHANGE THIS!
# Generate a random string: https://generate-secret.vercel.app/32
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING

# AI Provider - CHOOSE ONE:
# Get OpenAI key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# That's it! These 3 values are all you need to get started.
# For more options, see .env.example or AI-PROVIDERS.md
