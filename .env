# Database Configuration (PostgreSQL)
# For Docker: use 'postgres' as hostname (service name in docker-compose)
# For local: use 'localhost'
DATABASE_URL=postgresql://nonprofit_user:nonprofit_password_change_me@localhost:5432/nonprofit_ideas

# JWT Secret for authentication (generate a strong random string)
JWT_SECRET=nonprofit_jwt_secret_2024_xyz789_abc123_secure_random_key_v1

# Application Configuration
VITE_APP_ID=nonprofit-ideas-generator
NODE_ENV=development
PORT=3000

# OAuth Portal (Manus platform URL for frontend)
VITE_OAUTH_PORTAL_URL=https://oauth.manus.app

# Analytics (optional - disable if not needed)
VITE_ANALYTICS_ENDPOINT=

# OAuth Configuration (for Manus platform)
OAUTH_SERVER_URL=https://oauth.manus.app
OWNER_OPEN_ID=

# Built-in Forge API (for AI features, image generation, maps, etc.)
BUILT_IN_FORGE_API_URL=https://api.manus.app
BUILT_IN_FORGE_API_KEY=

# AI Provider Configuration (Choose ONE of the following)
# =====================================================

# Option 1: OpenAI API (Recommended for best quality)
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Option 2: OpenRouter (Access to multiple AI models)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# Option 3: Custom OpenAI-compatible API
# For local models (Ollama, LM Studio) or other providers
# CUSTOM_LLM_URL=http://localhost:11434/v1/chat/completions
